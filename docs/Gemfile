source "https://rubygems.org"

# Run the site with:
#
#     bundle install
#     bundle exec jekyll serve
#
gem "jekyll", "~> 4.4"

# Plugins
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"          # RSS/Atom feed for the blog
  gem "jekyll-seo-tag", "~> 2.8"        # <meta> tags, Open Graph, Twitter cards
  gem "jekyll-redirect-from", "~> 0.16" # redirect pages (e.g. /test-mobile → form)
end

# Windows and JRuby do not include zoneinfo files, so bundle the tzinfo-data gem
# and associated library.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Performance-booster for watching directories on Windows
gem "wdm", "~> 0.1", :platforms => [:mingw, :x64_mingw, :mswin]

# Lock `http_parser.rb` gem to `v0.6.x` on JRuby builds since newer versions of
# the gem do not have a Java counterpart.
gem "http_parser.rb", "~> 0.6.0", :platforms => [:jruby]
